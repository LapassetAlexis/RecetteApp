# Variables d'environnement pour le Menu Planner
# Copie ce fichier en .env et complète les valeurs

# Notion
NOTION_TOKEN=ntn_...

# Provider LLM : "ollama" (défaut, local), "gemini" ou "groq" (cloud, rapide)
LLM_PROVIDER=ollama

# Si LLM_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# Si LLM_PROVIDER=gemini (obtenir une clé sur https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash-001

# Si LLM_PROVIDER=groq (obtenir une clé sur https://console.groq.com/keys)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# App
APP_TITLE=Menu Planner Tristabeau
# Laisse vide pour générer une clé aléatoire au démarrage
SECRET_KEY=
